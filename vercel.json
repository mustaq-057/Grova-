{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run build:grova",
  "outputDirectory": "artifacts/instagram-clone/dist",
  "framework": null,
  "functions": {
    "api/**/*.mjs": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "artifacts/api-server/dist/**"
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
