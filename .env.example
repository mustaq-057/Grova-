# API server port (production: serves UI + API on this port)
PORT=5001

# Vite dev server port
VITE_PORT=5000

# Vite dev only - where to proxy /api requests
API_URL=http://localhost:5001

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5000

# Reverse proxy trust chain (Express trust proxy setting)
TRUSTED_PROXIES=loopback, linklocal, uniquelocal

# GIFs + Stickers (2000+ trending each, scroll to load) — free at https://developers.giphy.com/dashboard/
VITE_GIPHY_API_KEY=

# Database — Neon Postgres (cloud). Local dev fallback: file:./neon.db
# Get connection string from https://console.neon.tech → Connect
# Use the *pooled* connection string from Neon console. Do not add channel_binding=require (breaks Node).
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Server-side encryption key (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=

# Encryption password (required to access encryption key)
ENCRYPTION_PASSWORD=

# Cloudinary (preferred for posts, chat images, PDFs) — https://console.cloudinary.com
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Backblaze B2 Storage (fallback) - https://www.backblaze.com/b2/cloud-storage.html
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=grova-images
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com

# VAPID keys for push notifications (generate with: npx web-push generate-vapid-keys)
VITE_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Default couple code for initialization (required)
DEFAULT_COUPLE_CODE=

# Primary website gate before profile login (single allowed email)
PRIMARY_AUTH_EMAILS=your-email@example.com
# Use PRIMARY_AUTH_PASSWORD_1 for passwords with special characters (# , etc.)
PRIMARY_AUTH_PASSWORDS=
PRIMARY_AUTH_PASSWORD_1=

# WebRTC TURN (recommended for production / mobile networks behind NAT)
# Example: turn:your.turn.server:3478?transport=udp,turn:your.turn.server:3478?transport=tcp
TURN_SERVERS=
TURN_USERNAME=
TURN_CREDENTIAL=
# Optional extra STUN (comma-separated)
STUN_SERVERS=
